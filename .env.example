# Copy this file to .env and fill in the values before running any Flask app.
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development
WTF_CSRF_TIME_LIMIT=3600

# ── Database ────────────────────────────────────────────────────────────────
# Uncomment ONE of the DATABASE_URL lines below and fill in your credentials.
# The active line in your real .env must NOT be committed to version control.

# SQLite (default — no server required, file stored next to the app)
DATABASE_URL=sqlite:///wtforms_learn.db

# PostgreSQL (requires: pip install psycopg2-binary)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/dbname

# MySQL / MariaDB (requires: pip install pymysql)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/dbname

# Microsoft SQL Server (requires: pip install pyodbc + ODBC Driver 18)
# DATABASE_URL=mssql+pyodbc://user:password@server/dbname?driver=ODBC+Driver+18+for+SQL+Server

# ── Bcrypt ───────────────────────────────────────────────────────────────────
# Work factor (cost). Each +1 doubles hashing time. 12 is the 2024+ minimum.
BCRYPT_LOG_ROUNDS=12
